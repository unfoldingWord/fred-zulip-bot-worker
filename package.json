{
  "name": "fred-zulip-bot-worker",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:version": "node scripts/generate-version.mjs",
    "predev": "node scripts/generate-version.mjs",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "prebuild": "node scripts/generate-version.mjs",
    "build": "wrangler build",
    "version": "node scripts/generate-version.mjs && git add src/generated/version.ts",
    "pretest": "node scripts/generate-version.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "tsc --noEmit",
    "architecture": "depcruise --config .dependency-cruiser.js src",
    "audit:prod": "node scripts/audit-prod.mjs",
    "audit:all": "node scripts/audit-prod.mjs --include-dev --audit-level=high",
    "prepare": "husky"
  },
  "dependencies": {
    "@cf-wasm/quickjs": "^0.2.5",
    "hono": "^4.12.14",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.6",
    "@cloudflare/workers-types": "^4.20260414.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.17",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.2",
    "semver": "^7.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.72.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,css,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "undici": ">=7.24.0",
      "vite": "^6.4.2"
    }
  }
}
